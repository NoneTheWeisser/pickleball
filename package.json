{
  "name": "pickleball",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w server\" \"npm run dev -w client\"",
    "build": "npm run build -w client",
    "start": "node server/src/index.js",
    "deploy": "npm run build && fly deploy --ha=false"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
